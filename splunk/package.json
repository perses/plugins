{
  "name": "@perses-dev/splunk-plugin",
  "version": "0.1.0-beta.0",
  "homepage": "https://github.com/perses/plugins/blob/main/README.md",
  "bugs": {
    "url": "https://github.com/perses/plugins/issues"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/perses/plugins.git"
  },
  "files": [
    "lib/**/*",
    "__mf/**/*",
    "mf-manifest.json",
    "mf-stats.json"
  ],
  "main": "lib/cjs/index.js",
  "module": "lib/index.js",
  "types": "lib/index.d.ts",
  "scripts": {
    "dev": "rsbuild dev",
    "build": "npm run build-mf && concurrently \"npm:build:*\"",
    "build-mf": "rsbuild build",
    "build:cjs": "swc ./src -d dist/lib/cjs --strip-leading-paths --config-file ../.cjs.swcrc",
    "build:esm": "swc ./src -d dist/lib --strip-leading-paths --config-file ../.swcrc",
    "build:types": "tsc --project tsconfig.build.json",
    "lint": "oxlint src",
    "test": "cross-env LC_ALL=C TZ=UTC jest",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {},
  "devDependencies": {},
  "peerDependencies": {
    "@perses-dev/components": "^0.54.0-beta.7",
    "@perses-dev/plugin-system": "^0.54.0-beta.7",
    "@perses-dev/spec": "^0.2.0-beta.2",
    "immer": "^10.1.1",
    "react": "^17.0.2 || ^18.0.0"
  },
  "perses": {
    "moduleName": "Splunk",
    "schemasPath": "schemas",
    "plugins": [
      {
        "kind": "Datasource",
        "spec": {
          "display": {
            "name": "Splunk Datasource"
          },
          "name": "SplunkDatasource"
        }
      },
      {
        "kind": "TimeSeriesQuery",
        "spec": {
          "display": {
            "name": "Splunk Time Series Query"
          },
          "name": "SplunkTimeSeriesQuery"
        }
      },
      {
        "kind": "LogQuery",
        "spec": {
          "display": {
            "name": "Splunk Log Query"
          },
          "name": "SplunkLogQuery"
        }
      }
    ]
  }
}
